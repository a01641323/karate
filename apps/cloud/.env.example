# Vercel KV (auto-populated by the Vercel KV integration; do not set by hand)
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Ed25519 license-signing keypair. Generate with: pnpm --filter @karate/cloud generate-keypair
# Paste the PEM strings here. Newlines must be escaped as \n on Vercel.
KEY_PRIVATE_PEM=
KEY_PUBLIC_PEM=

# GitHub OAuth — create an app at https://github.com/settings/developers
# Authorization callback URL: https://<your-vercel-domain>/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Only this GitHub numeric user ID can reach /admin. Find yours via:
#   curl https://api.github.com/users/<your-handle> | jq .id
SUPERADMIN_GITHUB_ID=

# 32-byte hex strings (`openssl rand -hex 32`). Random per environment.
AUTH_SECRET=
COOKIE_SECRET=

# GitHub Releases binary delivery (used by /api/downloads/[os])
# Fine-scoped PAT, read-only on releases of the repo below.
GITHUB_RELEASE_PAT=
GITHUB_RELEASE_REPO=a01641323/karate
